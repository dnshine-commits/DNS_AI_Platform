[Unit]
Description=Emergency Bell Mock Control Server
After=network-online.target

[Service]
Type=simple
User=jetson
WorkingDirectory=/home/jetson/emergency-bell
ExecStart=/home/jetson/emergency-bell/venv/bin/uvicorn server.mock_server:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
